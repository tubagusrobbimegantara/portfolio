---
import { getTranslations, type Lang } from '../../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getTranslations(lang);
const tc = t.teaching;

const roleIcons = [
  `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
];
---

<!-- BANNER -->
<section class="banner">
  <div class="wrap">
    <div class="banner-grid">
      <div class="banner-copy">
        <span class="eyebrow">{tc.eyebrow}</span>
        <h1 class="display lg">{tc.h1} <em>{tc.h1em}</em></h1>
        <p class="banner-lede">{tc.lede}</p>
      </div>
      <div class="banner-art deco" aria-hidden="true">
        <div class="stack" style="position:absolute;top:70px;right:80px;width:140px;height:140px">
          <div class="stack-card" style="inset:0;opacity:0.25;transform:translate(30px,30px)"></div>
          <div class="stack-card" style="inset:0;opacity:0.5;transform:translate(15px,15px)"></div>
          <div class="stack-card" style="inset:0;display:flex;align-items:center;justify-content:center">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#05101e" stroke-width="2">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
          </div>
        </div>
        <div class="dots" style="position:absolute;bottom:20px;right:14px"><i></i><i></i><i></i></div>
      </div>
    </div>
  </div>
</section>

<hr class="rule">

<!-- ROLES -->
<section>
  <div class="wrap">
    <div class="sec-head rev">
      <span class="eyebrow">{tc.rolesEyebrow}</span>
      <h2 class="display md">{tc.rolesH2}</h2>
    </div>
    <div class="split">
      {tc.roles.map((role, i) => (
        <div class="card rev">
          <div class="meta-row" style="margin-bottom:0">
            <div class:list={['mi', role.iconClass]} set:html={roleIcons[i]}></div>
            <div class="mt">
              <span class="ml">{role.label}</span>
              <span class="mv">{role.title}</span>
              <span class="ms" set:html={role.sub.replace('\n', '<br>')}></span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<hr class="rule">

<!-- NEWS -->
<section>
  <div class="wrap">
    <div class="sec-head rev">
      <span class="eyebrow">{tc.newsEyebrow}</span>
      <h2 class="display lg">{tc.newsH2} <em>{tc.newsH2em}</em></h2>
    </div>
    <div class="news-list">
      {tc.news.map(item => (
        <div class="ni rev">
          <span class="ni-date">{item.date}</span>
          <span class:list={['ni-dot', item.type]}></span>
          <p class="ni-text" set:html={item.html}></p>
        </div>
      ))}
    </div>
  </div>
</section>

<hr class="rule">
