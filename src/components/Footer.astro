---
import { getTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<footer>
  <div class="wrap foot-grid">
    <div class="copy">{t.footer.copyright}</div>
    <div class="foot-links">
      <a href="https://scholar.google.com/citations?user=Tf4cRjcAAAAJ&hl=en&oi=ao" target="_blank" rel="noopener">{t.footer.scholar}</a>
      <a href="https://www.scopus.com/authid/detail.uri?authorId=57888526400" target="_blank" rel="noopener">{t.footer.scopus}</a>
      <a href="https://orcid.org/0000-0002-8888-5565" target="_blank" rel="noopener">{t.footer.orcid}</a>
      <a href="https://www.linkedin.com/in/tubagusrobbimegantara/" target="_blank" rel="noopener">{t.footer.linkedin}</a>
    </div>
  </div>
</footer>
