---
import Layout from '../layouts/Layout.astro';
import PublicationsPage from '../components/pages/PublicationsPage.astro';
import { getTranslations, type Lang } from '../i18n';

const lang = (Astro.currentLocale ?? 'id') as Lang;
const t = getTranslations(lang);
---
<Layout title={t.publications.meta.title} description={t.publications.meta.description} lang={lang} currentPath="/publications">
  <PublicationsPage lang={lang} />
</Layout>
